<?xml version="1.0"?>
<sdf version="1.9">
  <model name="maritime_radar">
    <static>false</static>

    <!-- 基座 (固定) -->
    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <geometry>
          <cylinder><radius>0.15</radius><length>0.3</length></cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
        </material>
      </visual>
      <collision name="base_collision">
        <geometry>
          <cylinder><radius>0.15</radius><length>0.3</length></cylinder>
        </geometry>
      </collision>
    </link>

    <!-- 天线 (旋转) -->
    <link name="antenna_link">
      <pose>0 0 0.2 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.05</ixx><iyy>0.2</iyy><izz>0.2</izz>
        </inertia>
      </inertial>
      <visual name="antenna_visual">
        <geometry>
          <box><size>1.0 0.05 0.1</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.8 1</ambient>
        </material>
      </visual>

      <!-- GPU LiDAR 传感器 -->
      <sensor name="radar_lidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>/maritime_radar/lidar</topic>
        <update_rate>250</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </horizontal>
            <vertical>
              <samples>256</samples>
              <resolution>1</resolution>
              <min_angle>-0.35</min_angle>
              <max_angle>0.1</max_angle>
            </vertical>
          </scan>
          <range>
            <min>1.0</min>
            <max>1500.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
      </sensor>
    </link>

    <!-- 旋转关节 -->
    <joint name="antenna_joint" type="revolute">
      <parent>base_link</parent>
      <child>antenna_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <!-- 关节控制器: 60 RPM = 6.283 rad/s -->
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>antenna_joint</joint_name>
      <initial_velocity>6.283185</initial_velocity>
    </plugin>

    <!-- 海事雷达插件 -->
    <plugin filename="MaritimeRadarPlugin"
            name="maritime_radar">
      <joint_name>antenna_joint</joint_name>
      <lidar_topic>/maritime_radar/lidar</lidar_topic>
      <radar_topic>/maritime_radar/radar/spokes</radar_topic>
      <angular_resolution>0.0251327</angular_resolution>
      <linear_resolution>0.75</linear_resolution>
      <min_range>1.0</min_range>
      <max_range>1500.0</max_range>
    </plugin>

  </model>
</sdf>
